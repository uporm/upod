{
  "apifoxProject": "1.0.0",
  "$schema": {
    "app": "apifox",
    "type": "project",
    "version": "1.2.0"
  },
  "info": {
    "name": "命令执行 API",
    "description": "用于执行命令、查询状态、中断命令和读取后台输出的接口文档",
    "mockRule": {
      "rules": [],
      "enableSystemRule": true
    }
  },
  "apiCollection": [
    {
      "name": "命令",
      "parentId": 0,
      "items": [
        {
          "name": "执行命令",
          "api": {
            "method": "post",
            "path": "/command",
            "status": "developing",
            "requestBody": {
              "type": "application/json",
              "parameters": [],
              "jsonSchema": {
                "type": "object",
                "required": [
                  "command"
                ],
                "properties": {
                  "command": {
                    "type": "string",
                    "description": "要执行的 shell 命令",
                    "example": "echo hello"
                  },
                  "cwd": {
                    "type": "string",
                    "description": "命令执行工作目录（可选）",
                    "example": "/tmp"
                  },
                  "background": {
                    "type": "boolean",
                    "description": "是否后台执行（可选，默认 false）",
                    "example": false
                  },
                  "timeout": {
                    "type": "integer",
                    "description": "超时时间（毫秒，可选）",
                    "example": 10000
                  }
                }
              },
              "examples": [
                {
                  "name": "前台执行示例",
                  "value": "{\n  \"command\": \"echo hello\",\n  \"cwd\": \"/tmp\",\n  \"background\": false,\n  \"timeout\": 10000\n}",
                  "mediaType": "application/json"
                },
                {
                  "name": "后台执行示例",
                  "value": "{\n  \"command\": \"sleep 10 && echo done\",\n  \"background\": true\n}",
                  "mediaType": "application/json"
                }
              ]
            },
            "responses": [
              {
                "code": 200,
                "name": "成功（SSE）",
                "contentType": "text/event-stream",
                "jsonSchema": {
                  "type": "object",
                  "required": [
                    "type"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "description": "事件类型：init/accepted/stdout/stderr/error/complete。后台模式通常只返回 init、accepted；前台模式会返回 stdout/stderr，并以 complete 结束"
                    },
                    "text": {
                      "type": "string",
                      "description": "文本内容。init 事件中为命令会话 id（32 位十六进制字符串，无连字符）"
                    },
                    "execution_time": {
                      "type": "integer",
                      "description": "执行耗时（毫秒）"
                    },
                    "error": {
                      "type": "object",
                      "required": [
                        "ename",
                        "evalue",
                        "traceback"
                      ],
                      "properties": {
                        "ename": {
                          "type": "string",
                          "description": "错误名称"
                        },
                        "evalue": {
                          "type": "string",
                          "description": "错误描述或退出码信息"
                        },
                        "traceback": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "错误堆栈或错误信息列表"
                        }
                      }
                    }
                  }
                }
              },
              {
                "code": 400,
                "name": "请求错误",
                "contentType": "text/plain",
                "jsonSchema": {
                  "type": "string",
                  "example": "命令不能为空"
                }
              }
            ],
            "commonParameters": {
              "query": [],
              "body": [],
              "cookie": [],
              "header": []
            }
          }
        },
        {
          "name": "中断命令",
          "api": {
            "method": "delete",
            "path": "/command",
            "status": "developing",
            "parameters": {
              "query": [
                {
                  "name": "id",
                  "type": "string",
                  "required": true,
                  "description": "命令会话 ID（由执行命令接口 init 事件返回）",
                  "example": "8f102b104a434fd49ae3becf1376f4ea"
                }
              ]
            },
            "responses": [
              {
                "code": 204,
                "name": "成功",
                "contentType": "text/plain",
                "jsonSchema": {
                  "type": "null"
                }
              },
              {
                "code": 404,
                "name": "未找到会话",
                "contentType": "text/plain",
                "jsonSchema": {
                  "type": "string",
                  "example": "命令会话不存在或已结束"
                }
              }
            ],
            "commonParameters": {
              "query": [],
              "body": [],
              "cookie": [],
              "header": []
            }
          }
        },
        {
          "name": "获取命令状态",
          "api": {
            "method": "get",
            "path": "/command/status/{id}",
            "status": "developing",
            "parameters": {
              "path": [
                {
                  "name": "id",
                  "type": "string",
                  "description": "命令会话 ID",
                  "example": "8f102b104a434fd49ae3becf1376f4ea"
                }
              ]
            },
            "responses": [
              {
                "code": 200,
                "name": "成功",
                "contentType": "json",
                "jsonSchema": {
                  "type": "object",
                  "required": [
                    "id",
                    "content",
                    "running",
                    "started_at"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "命令会话 ID"
                    },
                    "content": {
                      "type": "string",
                      "description": "原始命令文本"
                    },
                    "running": {
                      "type": "boolean",
                      "description": "是否仍在运行"
                    },
                    "exit_code": {
                      "type": "integer",
                      "description": "退出码（运行中时为空）"
                    },
                    "error": {
                      "type": "string",
                      "description": "错误信息（成功时为空）"
                    },
                    "started_at": {
                      "type": "integer",
                      "description": "开始时间（毫秒时间戳）"
                    },
                    "finished_at": {
                      "type": "integer",
                      "description": "结束时间（毫秒时间戳，运行中时为空）"
                    }
                  }
                }
              },
              {
                "code": 404,
                "name": "未找到会话",
                "contentType": "text/plain",
                "jsonSchema": {
                  "type": "string",
                  "example": "未找到命令会话"
                }
              }
            ],
            "commonParameters": {
              "query": [],
              "body": [],
              "cookie": [],
              "header": []
            }
          }
        },
        {
          "name": "获取后台命令输出",
          "api": {
            "method": "get",
            "path": "/command/output/{id}",
            "status": "developing",
            "parameters": {
              "path": [
                {
                  "name": "id",
                  "type": "string",
                  "description": "命令会话 ID",
                  "example": "8f102b104a434fd49ae3becf1376f4ea"
                }
              ],
              "query": [
                {
                  "name": "cursor",
                  "type": "integer",
                  "description": "读取偏移量，默认 0",
                  "example": 0
                }
              ]
            },
            "responses": [
              {
                "code": 200,
                "name": "成功",
                "contentType": "text/plain",
                "jsonSchema": {
                  "type": "string",
                  "description": "从 cursor 开始的增量输出文本"
                }
              },
              {
                "code": 500,
                "name": "读取失败",
                "contentType": "text/plain",
                "jsonSchema": {
                  "type": "string",
                  "example": "Seek failed"
                }
              }
            ],
            "commonParameters": {
              "query": [],
              "body": [],
              "cookie": [],
              "header": [
                {
                  "name": "EXECD-COMMANDS-TAIL-CURSOR",
                  "type": "string",
                  "description": "下一次增量读取时应使用的 cursor"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
